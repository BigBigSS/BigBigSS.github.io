---
import type { CollectionEntry } from "astro:content";
import { spectrum } from "../data/site";
import { formatCompactDate } from "../lib/content";
import SectionHeading from "./SectionHeading.astro";

interface Props {
  posts: CollectionEntry<"posts">[];
}

const { posts } = Astro.props;
---

<section class="carousel section" id="writing">
  <div class="page-shell">
    <SectionHeading
      index="04"
      label="writing"
      title="写作"
    />

    <div class="carousel__surface" data-carousel-root>
      <div class="carousel__viewport">
        <ol class="carousel__track">
          {
            posts.map((post, index) => (
              <li
                class="carousel-card"
                data-carousel-card
                style={`--accent: ${spectrum[index % spectrum.length]};`}
              >
                <a class="card-link carousel-card__link" href={`/posts/${post.id}`}>
                  <div class="carousel-card__top">
                    <span class="carousel-card__index">{String(index + 1).padStart(2, "0")}</span>
                    <span class="carousel-card__date">{formatCompactDate(post.data.date)}</span>
                  </div>

                  <div class="carousel-card__body">
                    <h3>{post.data.title}</h3>
                    <p>{post.data.description}</p>
                  </div>

                  <ul class="tag-list">
                    {post.data.tags.map((tag) => <li class="tag-pill">{tag}</li>)}
                  </ul>
                </a>
              </li>
            ))
          }
        </ol>
      </div>

      <p class="carousel__hint">Drag to steer · Hover to pause</p>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll("[data-carousel-root]").forEach((root) => {
    if (!(root instanceof HTMLElement) || window.matchMedia("(max-width: 900px)").matches) {
      return;
    }

    const cards = Array.from(root.querySelectorAll<HTMLElement>("[data-carousel-card]"));
    if (!cards.length) {
      return;
    }

    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const autoVelocity = reduced ? 0 : cards.length / 80000;
    const frameInterval = 1000 / 30;
    let rotation = 0;
    let velocity = autoVelocity;
    let paused = false;
    let dragging = false;
    let inViewport = false;
    let running = false;
    let scrollSuspended = document.body.classList.contains("is-scrolling");
    let lastX = 0;
    let frame = 0;
    let lastTime = performance.now();
    let lastPaint = 0;
    const cardState = cards.map(() => ({
      offset: Number.NaN,
      distance: Number.NaN,
      zIndex: "",
      active: false,
    }));

    const wrapOffset = (value: number) => {
      let offset = value;
      const half = cards.length / 2;

      while (offset > half) {
        offset -= cards.length;
      }

      while (offset < -half) {
        offset += cards.length;
      }

      return offset;
    };

    const apply = (force = false) => {
      cards.forEach((card, index) => {
        const offset = wrapOffset(index - rotation);
        const distance = Math.abs(offset);
        const zIndex = String(100 - Math.round(distance * 10));
        const active = distance < 0.24;
        const state = cardState[index];

        if (force || Math.abs(state.offset - offset) > 0.002) {
          state.offset = offset;
          card.style.setProperty("--offset", offset.toFixed(4));
        }

        if (force || Math.abs(state.distance - distance) > 0.002) {
          state.distance = distance;
          card.style.setProperty("--distance", distance.toFixed(4));
        }

        if (force || state.zIndex !== zIndex) {
          state.zIndex = zIndex;
          card.style.zIndex = zIndex;
        }

        if (force || state.active !== active) {
          state.active = active;
          card.classList.toggle("is-active", active);
        }
      });
    };

    const stop = () => {
      if (!running) {
        return;
      }

      running = false;
      window.cancelAnimationFrame(frame);
      frame = 0;
    };

    const start = () => {
      // 自愈：若在异步初始化期间错过 page-scroll-end，用实时的 is-scrolling 状态纠正挂起标记
      if (scrollSuspended && !document.body.classList.contains("is-scrolling")) {
        scrollSuspended = false;
      }
      if (
        running ||
        !inViewport ||
        scrollSuspended ||
        document.visibilityState === "hidden" ||
        (reduced && !dragging) ||
        (paused && !dragging)
      ) {
        return;
      }

      lastTime = performance.now();
      lastPaint = lastTime;
      running = true;
      frame = window.requestAnimationFrame(tick);
    };

    const tick = (now: number) => {
      if (!running) {
        return;
      }

      const delta = now - lastTime;
      lastTime = now;

      if (!dragging && !paused && !reduced) {
        rotation += velocity * delta;
        velocity += (autoVelocity - velocity) * 0.04;
      }

      if (dragging || now - lastPaint >= frameInterval) {
        apply();
        lastPaint = now;
      }

      frame = window.requestAnimationFrame(tick);
    };

    const onMouseEnter = () => {
      paused = true;
      if (!dragging) {
        stop();
      }
    };

    const onMouseLeave = () => {
      paused = false;
      start();
    };

    const onPointerDown = (event: PointerEvent) => {
      dragging = true;
      paused = true;
      lastX = event.clientX;
      root.setPointerCapture?.(event.pointerId);
      start();
    };

    const onPointerMove = (event: PointerEvent) => {
      if (!dragging) {
        return;
      }

      const delta = event.clientX - lastX;
      lastX = event.clientX;
      rotation -= delta * 0.012;
      velocity = -delta * 0.00018;
      apply();
    };

    const release = (event: PointerEvent) => {
      dragging = false;
      paused = false;
      if (root.hasPointerCapture?.(event.pointerId)) {
        root.releasePointerCapture(event.pointerId);
      }
      start();
    };

    const onVisibilityChange = () => {
      if (document.visibilityState === "hidden") {
        stop();
      } else {
        start();
      }
    };

    const onScrollStart = () => {
      scrollSuspended = true;
      root.setAttribute("data-scroll-suspended", "");
      stop();
    };

    const onScrollEnd = () => {
      scrollSuspended = false;
      root.removeAttribute("data-scroll-suspended");
      start();
    };

    const visibilityObserver =
      "IntersectionObserver" in window
        ? new IntersectionObserver(
            (entries) => {
              inViewport = entries.some((entry) => entry.isIntersecting);
              root.toggleAttribute("data-carousel-active", inViewport);

              if (inViewport) {
                start();
              } else {
                stop();
              }
            },
            { rootMargin: "64px 0px", threshold: 0.16 },
          )
        : undefined;

    root.addEventListener("mouseenter", onMouseEnter);
    root.addEventListener("mouseleave", onMouseLeave);
    root.addEventListener("pointerdown", onPointerDown);
    root.addEventListener("pointermove", onPointerMove);
    root.addEventListener("pointerup", release);
    root.addEventListener("pointercancel", release);
    document.addEventListener("visibilitychange", onVisibilityChange);
    window.addEventListener("page-scroll-start", onScrollStart as EventListener);
    window.addEventListener("page-scroll-end", onScrollEnd as EventListener);

    apply(true);
    if (visibilityObserver) {
      visibilityObserver.observe(root);
    } else {
      inViewport = true;
      root.setAttribute("data-carousel-active", "");
      start();
    }

    window.addEventListener("beforeunload", () => {
      stop();
      visibilityObserver?.disconnect();
      document.removeEventListener("visibilitychange", onVisibilityChange);
      window.removeEventListener("page-scroll-start", onScrollStart as EventListener);
      window.removeEventListener("page-scroll-end", onScrollEnd as EventListener);
    }, {
      once: true,
    });
  });
</script>

<style>
  .carousel__surface {
    position: relative;
    width: 100vw;
    margin-top: 48px;
    margin-left: calc(50% - 50vw);
    overflow: hidden;
    content-visibility: auto;
    contain-intrinsic-size: 560px;
    touch-action: pan-y;
  }

  .carousel__surface::before,
  .carousel__surface::after {
    position: absolute;
    inset: 0;
    pointer-events: none;
    content: "";
  }

  .carousel__surface::before {
    background:
      radial-gradient(circle at 24% 30%, rgba(132, 204, 22, 0.14), transparent 28%),
      radial-gradient(circle at 78% 26%, rgba(99, 102, 241, 0.18), transparent 30%);
  }

  .carousel__viewport {
    position: relative;
    height: 470px;
    perspective: 1200px;
  }

  .carousel__track {
    position: relative;
    height: 100%;
    margin: 0;
    padding: 0;
    list-style: none;
    transform-style: preserve-3d;
  }

  .carousel-card {
    --offset: 0;
    --distance: 0;
    position: absolute;
    top: 26px;
    left: 50%;
    width: min(360px, 30vw);
    min-height: 340px;
    transform-style: preserve-3d;
    transform-origin: center;
    backface-visibility: hidden;
    contain: layout style paint;
    transform:
      translate3d(
        calc(-50% + (var(--offset) * 78%)),
        calc(var(--distance) * 8px),
        calc(var(--distance) * -160px)
      )
      rotateY(calc(var(--offset) * -24deg))
      scale(calc(1 - (var(--distance) * 0.08)));
    opacity: calc(1 - (var(--distance) * 0.18));
  }

  .carousel__surface[data-carousel-active]:not([data-scroll-suspended]) .carousel-card {
    will-change: transform, opacity;
  }

  .carousel-card.is-active {
    opacity: 1;
  }

  .carousel-card__link {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 22px;
    min-height: 100%;
    padding: 24px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 30px;
    background:
      radial-gradient(circle at 24% 18%, color-mix(in srgb, var(--accent) 24%, transparent), transparent 32%),
      linear-gradient(180deg, rgba(17, 24, 39, 0.9), rgba(2, 6, 23, 0.96));
    box-shadow: 0 18px 42px rgba(0, 0, 0, 0.26);
    color: #f8fafc;
    transform: translateZ(0);
  }

  .carousel-card__top {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    color: rgba(255, 255, 255, 0.44);
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.78rem;
  }

  .carousel-card__body h3 {
    margin: 0;
    font-size: clamp(1.6rem, 2.1vw, 2.2rem);
    line-height: 1.12;
    letter-spacing: -0.04em;
  }

  .carousel-card__body p {
    margin: 16px 0 0;
    color: rgba(255, 255, 255, 0.68);
  }

  .carousel__surface :global(.tag-pill) {
    background: rgba(20, 184, 166, 0.12);
    color: rgba(153, 246, 228, 0.9);
  }

  .carousel__hint {
    margin: 18px 0 0;
    color: rgba(255, 255, 255, 0.42);
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  @media (max-width: 900px) {
    .carousel__viewport {
      height: auto;
      perspective: none;
    }

    .carousel__track {
      display: grid;
      grid-auto-flow: column;
      grid-auto-columns: minmax(280px, 82vw);
      gap: 18px;
      overflow-x: auto;
      padding-bottom: 8px;
      scroll-snap-type: x proximity;
    }

    .carousel-card {
      position: relative;
      top: auto;
      left: auto;
      width: auto;
      min-height: 300px;
      transform: none;
      opacity: 1;
      filter: none;
      z-index: auto;
    }

    .carousel-card__link {
      min-height: 300px;
    }

    .carousel__hint {
      padding-inline: 16px;
    }
  }
</style>
