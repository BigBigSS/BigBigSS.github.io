    overflow: hidden;
    background:
      radial-gradient(circle at 48% 36%, rgba(94, 234, 212, 0.045), transparent 34%),
      linear-gradient(180deg, transparent 0%, color-mix(in srgb, var(--bg) 92%, black 8%) 18%, var(--bg) 100%);
    isolation: isolate;
  }

  :global(body.light-mode) .barrel3d {
    background:
      radial-gradient(circle at 48% 36%, rgba(99, 102, 241, 0.06), transparent 34%),
      linear-gradient(180deg, transparent 0%, color-mix(in srgb, var(--bg) 94%, white 6%) 18%, var(--bg) 100%);
  }

  .barrel3d__stage {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .barrel3d__stage :global(canvas) {
    display: block;
    width: 100% !important;
    height: 100% !important;
  }

  .barrel3d__eyebrow {
    position: absolute;
    top: clamp(26px, 4vw, 52px);
    left: max(24px, calc((100vw - var(--container)) / 2));
    z-index: 10;
    margin: 0;
    color: var(--text-tertiary);
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.76rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    pointer-events: none;
  }

  :global(body.light-mode) .barrel3d__eyebrow {
    color: rgba(0, 0, 0, 0.46);
  }

  @media (max-width: 720px) {
    .barrel3d {
      min-height: 680px;
    }
  }
</style>
