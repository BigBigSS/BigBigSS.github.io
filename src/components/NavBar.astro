---
import { navLinks, site } from "../data/site";

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const isActive = (href: string) => {
  if (href === "/") {
    return currentPath === "/";
  }

  if (href.startsWith("/#")) {
    return currentPath === "/";
  }

  return currentPath === href || currentPath.startsWith(`${href}/`);
};
---

<header class="nav-wrap">
  <div class="nav-inner" data-nav>
    <div class="nav-active-indicator" aria-hidden="true" data-nav-indicator></div>
    
    <a class="brand" href="/" aria-label={`${site.name} 首页`} data-magnetic>
      <span class="brand__text">{site.name}</span>
    </a>

    <nav class="nav-links" aria-label="主要导航">
      {
        navLinks.map((link) => {
          const active = isActive(link.href);
          return (
            <a
              class:list={["nav-link", { "is-active": active }]}
              href={link.href}
              data-nav-link
              data-magnetic
            >
              <span class="nav-link__label">{link.label}</span>
            </a>
          );
        })
      }
    </nav>
    
    <div class="nav-actions">
      <a class="nav-icon" href={site.github} target="_blank" rel="noreferrer" aria-label="GitHub" data-magnetic>
        <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
          <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
          <path d="M9 18c-4.51 2-5-2-7-2" />
        </svg>
      </a>
    </div>
  </div>
</header>

<script>
  const nav = document.querySelector<HTMLElement>("[data-nav]");
  const indicator = document.querySelector<HTMLElement>("[data-nav-indicator]");
  const links = document.querySelectorAll<HTMLElement>("[data-nav-link]");
  const magnetics = document.querySelectorAll<HTMLElement>("[data-magnetic]");

  const navWindow = window as typeof window & {
    __navScrollCleanup?: () => void;
  };

  if (nav && indicator) {
    navWindow.__navScrollCleanup?.();

    // 1. Scroll logic
    let frameId = 0;
    let lastScrolled = false;

    const syncScroll = () => {
      frameId = 0;
      const nextScrolled = window.scrollY > 50;
      if (nextScrolled === lastScrolled) return;
      lastScrolled = nextScrolled;
      nav.classList.toggle("is-scrolled", nextScrolled);
    };

    const requestSyncScroll = () => {
      if (frameId) return;
      frameId = window.requestAnimationFrame(syncScroll);
    };

    requestSyncScroll();
    window.addEventListener("scroll", requestSyncScroll, { passive: true });

    // 2. Sliding Indicator Logic
    const updateIndicator = (target: HTMLElement | null) => {
      if (!target) {
        indicator.style.opacity = "0";
        indicator.style.transform = `translate3d(0, 0, 0) scaleX(0.5)`;
        return;
      }
      
      const navRect = nav.getBoundingClientRect();
      const targetRect = target.getBoundingClientRect();
      
      const left = targetRect.left - navRect.left;
      const width = targetRect.width;

      indicator.style.opacity = "1";
      indicator.style.width = `${width}px`;
      indicator.style.transform = `translate3d(${left}px, 0, 0)`;
    };

    // Find active link initially
    let activeLink = Array.from(links).find(l => l.classList.contains("is-active")) as HTMLElement | undefined;
    
    // Initial Setting
    const initIndicator = () => {
        if(activeLink) {
           indicator.style.transition = 'none';
           updateIndicator(activeLink);
           // Force reflow
           indicator.offsetHeight;
           indicator.style.transition = '';
        }
    };
    
    // Allow fonts to load or UI to settle
    setTimeout(initIndicator, 100);
    // Also init immediately if possible
    initIndicator();

    nav.addEventListener("mouseleave", () => {
       updateIndicator(activeLink || null);
    });

    links.forEach(link => {
      link.addEventListener("mouseenter", () => {
        updateIndicator(link);
      });
      link.addEventListener("focus", () => {
        updateIndicator(link);
      });
    });

    // 3. Magnetic Logic
    // High-performance smooth magnetic implementation using rAF and lerp
    magnetics.forEach(el => {
      let bounds = el.getBoundingClientRect();
      let mouseX = 0;
      let mouseY = 0;
      let currentX = 0;
      let currentY = 0;
      let runId = 0;
      let isHovered = false;

      const lerp = (start: number, end: number, amt: number) => {
        return (1 - amt) * start + amt * end;
      };

      const animate = () => {
        if (!isHovered && Math.abs(mouseX - currentX) < 0.05 && Math.abs(mouseY - currentY) < 0.05) {
            currentX = 0;
            currentY = 0;
            el.style.transform = `translate3d(0, 0, 0)`;
            cancelAnimationFrame(runId);
            runId = 0;
            return;
        }

        currentX = lerp(currentX, mouseX, 0.12);
        currentY = lerp(currentY, mouseY, 0.12);

        el.style.transform = `translate3d(${currentX}px, ${currentY}px, 0)`;
        runId = requestAnimationFrame(animate);
      };

      el.addEventListener("mouseenter", () => {
        bounds = el.getBoundingClientRect();
        isHovered = true;
        if (!runId) runId = requestAnimationFrame(animate);
      });

      el.addEventListener("mousemove", (e) => {
        // Recalculate bounds occasionally or assume mostly static for perf
        // It's mostly fine unless window resizes heavily while hovering
        const x = e.clientX - bounds.left - bounds.width / 2;
        const y = e.clientY - bounds.top - bounds.height / 2;
        
        mouseX = x * 0.12;
        mouseY = y * 0.12;
      });

      el.addEventListener("mouseleave", () => {
        isHovered = false;
        mouseX = 0;
        mouseY = 0;
      });
    });

    navWindow.__navScrollCleanup = () => {
      if (frameId) {
        window.cancelAnimationFrame(frameId);
        frameId = 0;
      }
      window.removeEventListener("scroll", requestSyncScroll);
    };
  }
</script>

<style>
  .nav-wrap {
    position: fixed;
    top: 24px;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    justify-content: center;
    pointer-events: none;
    transition: top 400ms var(--ease-cinema);
  }

  .nav-inner {
    /* Top Tier Glassmorphism Tokens */
    --nav-bg: rgba(10, 11, 14, 0.45);
    --nav-bg-scrolled: rgba(10, 11, 14, 0.72);
    --nav-border: rgba(255, 255, 255, 0.08);
    --nav-border-scrolled: rgba(255, 255, 255, 0.14);
    --nav-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
    --nav-shadow-scrolled: 0 16px 48px rgba(0, 0, 0, 0.35);
    --nav-pill-bg: rgba(255, 255, 255, 0.08);
    --nav-pill-border: rgba(255, 255, 255, 0.05);

    position: relative;
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: min(600px, calc(100vw - 32px));
    height: 56px;
    padding: 0 8px 0 20px;
    
    background: var(--nav-bg);
    border: 1px solid var(--nav-border);
    border-radius: 999px; /* Capsule shape */
    
    /* Strong crystal blur */
    backdrop-filter: blur(12px) saturate(1.4);
    -webkit-backdrop-filter: blur(12px) saturate(1.4);
    box-shadow: var(--nav-shadow);
    
    pointer-events: auto;
    
    transition:
      background 400ms var(--ease-cinema),
      border-color 400ms var(--ease-cinema),
      box-shadow 400ms var(--ease-cinema),
      transform 400ms var(--ease-cinema);
  }

  /* Thin Inner highlight line for cinematic edge/rim lighting */
  .nav-inner::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.15) 0%, rgba(255, 255, 255, 0) 100%);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }

  :global(html.theme-preboot-light) .nav-inner,
  :global(body.light-mode) .nav-inner {
    --nav-bg: rgba(255, 255, 255, 0.55);
    --nav-bg-scrolled: rgba(255, 255, 255, 0.85);
    --nav-border: rgba(0, 0, 0, 0.06);
    --nav-border-scrolled: rgba(0, 0, 0, 0.12);
    --nav-shadow: 0 8px 32px rgba(0, 0, 0, 0.05);
    --nav-shadow-scrolled: 0 16px 48px rgba(0, 0, 0, 0.1);
    --nav-pill-bg: rgba(0, 0, 0, 0.06);
    --nav-pill-border: rgba(0, 0, 0, 0.04);
  }

  :global(html.theme-preboot-light) .nav-inner::before,
  :global(body.light-mode) .nav-inner::before {
     background: linear-gradient(180deg, rgba(255, 255, 255, 0.8) 0%, rgba(255, 255, 255, 0) 100%);
  }

  .nav-inner.is-scrolled {
    background: var(--nav-bg-scrolled);
    border-color: var(--nav-border-scrolled);
    box-shadow: var(--nav-shadow-scrolled);
    transform: translateY(-8px);
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-inner {
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
    }
  }

  .nav-active-indicator {
    position: absolute;
    top: 50%;
    left: 0;
    height: 38px;
    margin-top: -19px;
    background: var(--nav-pill-bg);
    border: 1px solid var(--nav-pill-border);
    border-radius: 999px;
    z-index: 0;
    opacity: 0;
    pointer-events: none;
    will-change: transform, width, opacity;
    /* Soft snappy spring transition */
    transition: 
      transform 0.4s cubic-bezier(0.25, 1, 0.35, 1),
      width 0.35s cubic-bezier(0.25, 1, 0.35, 1),
      opacity 0.3s ease;
  }

  .brand,
  .nav-link,
  .nav-icon {
    position: relative;
    z-index: 1;
    will-change: transform;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    min-width: 72px;
    color: var(--text-primary);
  }

  .brand__text {
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    font-family: var(--font-dm-sans, "DM Sans", sans-serif);
  }

  .nav-links {
    display: flex;
    align-items: stretch;
    flex: 1;
    justify-content: center;
    gap: 4px;
    position: relative;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 40px;
    padding: 0 16px;
    color: var(--text-secondary);
    font-size: 0.9rem;
    font-weight: 500;
    line-height: 1;
    transition: color 250ms var(--ease-cinema);
    border-radius: 999px;
    font-family: var(--font-dm-sans, "DM Sans", sans-serif);
  }

  .nav-link__label {
    letter-spacing: 0.02em;
  }

  .nav-link:hover,
  .nav-link:focus-visible,
  .nav-link.is-active {
    color: var(--text-primary);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    margin-left: auto;
  }

  .nav-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    color: var(--text-secondary);
    transition:
      color 220ms var(--ease-cinema),
      background-color 220ms var(--ease-cinema);
  }

  .nav-icon:hover,
  .nav-icon:focus-visible {
    color: var(--text-primary);
  }

  @media (max-width: 768px) {
    .nav-wrap {
      top: 16px;
    }

    .nav-inner {
      min-width: min(480px, calc(100vw - 24px));
      height: 52px;
      padding: 0 6px 0 14px;
    }

    .brand {
      min-width: 42px;
    }

    .nav-link {
      padding: 0 10px;
      font-size: 0.85rem;
    }

    .nav-active-indicator {
      height: 34px;
      margin-top: -17px;
    }
  }
</style>
