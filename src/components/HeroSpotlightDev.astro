---
import { site } from "../data/site";
---

<section class="hero">
  <div class="noise-overlay" aria-hidden="true"></div>
  <div class="ambient-glow" aria-hidden="true"></div>

  <!-- 背景场景 (基础极浅态打底) -->
  <div class="scene-container dim-scene" aria-hidden="true">
    <div class="ribbon ribbon-1"></div>
    <div class="ribbon ribbon-2"></div>
    <div class="ribbon ribbon-3"></div>
    <div class="ribbon ribbon-4"></div>
  </div>

  <!-- 炫丽高光常驻态 -->
  <div class="scene-container mouse-scene" aria-hidden="true">
    <div class="ribbon ribbon-1"></div>
    <div class="ribbon ribbon-2"></div>
    <div class="ribbon ribbon-3"></div>
    <div class="ribbon ribbon-4"></div>
  </div>

  <div class="hero__shell">
    <div class="hero__content">
      <div class="hero__tag ui-glass ui-text-main">DIGITAL ATELIER // 01</div>

      <h1 class="hero__title ui-text-main">
        Between Code<br />
        and <span class="ui-gradient-text">Passing Light</span>
      </h1>

      <p class="hero__lead ui-text-muted">
        生活中，保存一些可被再次打开的瞬间。
      </p>

      <div class="hero__actions">
        <a
          href={site.github}
          target="_blank"
          rel="noreferrer"
          class="hero__chip ui-glass ui-text-main"
        >
          <span>GITHUB</span>
        </a>

        <div class="hero__chip hero__chip--pop ui-glass ui-text-main">
          <span>WECHAT</span>
          <div class="hero__popover ui-glass">暂不展示</div>
        </div>

        <button
          type="button"
          class="hero__chip ui-glass ui-text-main"
          data-email-copy={site.email}
        >
          <span>CONTACT</span>
        </button>
      </div>
    </div>
  </div>
</section>


<style is:global>
  .hero {
    position: relative;
    width: 100%;
    height: clamp(760px, 108dvh, 980px);
    min-height: 760px;
    overflow: hidden;
    isolation: isolate;
    color: var(--ui-text-main);
  }

  .hero .noise-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    pointer-events: none;
    z-index: 50;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
    mix-blend-mode: var(--noise-blend, overlay);
    opacity: var(--noise-opacity, 0.04);
    transition: opacity 0.7s ease, mix-blend-mode 0.7s ease;
  }

  .hero[data-hero-wave-active] .ui-glass:hover,
  .hero[data-hero-wave-active] .ui-glass:focus-visible {
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  .hero .ambient-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background: var(--ambient-glow);
    transition: background 0.7s ease;
  }

  .hero::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 45;
    height: clamp(96px, 15vh, 180px);
    pointer-events: none;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      color-mix(in srgb, var(--bg) 24%, transparent) 62%,
      var(--bg) 100%
    );
  }

  .hero .scene-container {
    position: absolute;
    top: -12vh;
    right: -13vw;
    width: 82vw;
    height: 190vh;
    perspective: 1200px;
    transform-style: preserve-3d;
    pointer-events: none;
    contain: layout paint style;
    mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      #000 9%,
      #000 86%,
      rgba(0, 0, 0, 0.74) 94%,
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      #000 9%,
      #000 86%,
      rgba(0, 0, 0, 0.74) 94%,
      transparent 100%
    );
  }

  .hero .dim-scene {
    z-index: 1;
    opacity: var(--dim-opacity);
    filter: var(--dim-filter);
    transition: opacity 0.7s ease, filter 0.7s ease;
  }

  .hero .mouse-scene {
    z-index: 2;
    opacity: 0.95;
  }

  html.theme-preboot-light .hero .mouse-scene,
  body.light-mode .hero .mouse-scene {
    opacity: 0.85;
  }

  .hero .ribbon {
    position: absolute;
    height: 140%;
    top: -20%;
    border-radius: 50% 50% 50% 50% / 40% 60% 40% 60%;
    transform-style: preserve-3d;
    box-shadow: var(--ribbon-shadow);
    animation: float 12s ease-in-out infinite alternate;
    transition: box-shadow 0.7s ease;
  }

  .hero .ribbon-1 {
    width: 35vw;
    left: 0;
    z-index: 10;
    --rz: 5deg;
    --ry: -15deg;
    --tz: -100px;
    background: linear-gradient(105deg, #000 0%, #090314 15%, #230d52 35%, #6432c9 47%, #a78aed 49.5%, #ffffff 50.5%, #a78aed 51.5%, #411a91 60%, #0f0529 80%, #000 100%);
    animation-delay: 0s;
  }

  .hero .ribbon-2 {
    width: 40vw;
    left: 18vw;
    z-index: 20;
    --rz: -2deg;
    --ry: -25deg;
    --tz: 0px;
    background: linear-gradient(110deg, #000 0%, #02171c 10%, #0a4c5e 30%, #209da8 46%, #8bf2ed 49.5%, #ffffff 50.5%, #8bf2ed 51.5%, #18786e 60%, #052b21 80%, #000 100%);
    animation-delay: -3s;
  }

  .hero .ribbon-3 {
    width: 45vw;
    left: 40vw;
    z-index: 30;
    --rz: -10deg;
    --ry: -35deg;
    --tz: 100px;
    background: linear-gradient(115deg, #000 0%, #1f0300 10%, #610f00 25%, #b82c00 42%, #f28d13 48.5%, #ffebb3 50%, #ffffff 50.5%, #ffebb3 51%, #d9660b 58%, #5e1400 80%, #000 100%);
    animation-delay: -6s;
  }

  .hero .ribbon-4 {
    width: 38vw;
    left: 65vw;
    z-index: 40;
    --rz: -18deg;
    --ry: -45deg;
    --tz: 200px;
    background: linear-gradient(110deg, #000 0%, #1f0012 10%, #5e0431 30%, #ab1862 46%, #f07ab9 49.5%, #ffffff 50.5%, #f07ab9 51.5%, #8f0e4d 60%, #240114 80%, #000 100%);
    animation-delay: -9s;
  }

  html.theme-preboot-light .hero .ribbon-1,
  body.light-mode .hero .ribbon-1 {
    background: linear-gradient(105deg, rgba(255,255,255,0) 0%, rgba(243,232,255,0.6) 15%, #f3e8ff 30%, #a855f7 48%, #ffffff 50%, #e9d5ff 53%, rgba(168,85,247,0.25) 75%, rgba(255,255,255,0) 100%);
  }

  html.theme-preboot-light .hero .ribbon-2,
  body.light-mode .hero .ribbon-2 {
    background: linear-gradient(110deg, rgba(255,255,255,0) 0%, rgba(204,251,241,0.6) 15%, #ccfbf1 30%, #14b8a6 48%, #ffffff 50%, #99f6e4 53%, rgba(45,212,191,0.25) 75%, rgba(255,255,255,0) 100%);
  }

  html.theme-preboot-light .hero .ribbon-3,
  body.light-mode .hero .ribbon-3 {
    background: linear-gradient(115deg, rgba(255,255,255,0) 0%, rgba(255,237,213,0.6) 15%, #ffedd5 30%, #f97316 48%, #ffffff 50%, #fed7aa 53%, rgba(249,115,22,0.25) 75%, rgba(255,255,255,0) 100%);
  }

  html.theme-preboot-light .hero .ribbon-4,
  body.light-mode .hero .ribbon-4 {
    background: linear-gradient(110deg, rgba(255,255,255,0) 0%, rgba(252,231,243,0.6) 15%, #fce7f3 30%, #ec4899 48%, #ffffff 50%, #fbcfe8 53%, rgba(236,72,153,0.25) 75%, rgba(255,255,255,0) 100%);
  }

  @keyframes float {
    0% {
      transform: translateY(0) rotateZ(var(--rz, 0deg)) rotateY(var(--ry, 0deg)) translateZ(var(--tz, 0deg));
    }
    100% {
      transform: translateY(-3vh) rotateZ(var(--rz, 0deg)) rotateY(var(--ry, 0deg)) translateZ(var(--tz, 0deg));
    }
  }

  .ribbon-1 { --rz: 5deg; --ry: -15deg; --tz: -100px; animation-delay: 0s; }
  .ribbon-2 { --rz: -2deg; --ry: -25deg; --tz: 0px; animation-delay: -3s;}
  .ribbon-3 { --rz: -10deg; --ry: -35deg; --tz: 100px; animation-delay: -6s;}
  .ribbon-4 { --rz: -18deg; --ry: -45deg; --tz: 200px; animation-delay: -9s;}

  @media (prefers-reduced-motion: reduce) {
    .hero .ribbon {
      animation: none;
    }
  }

  .hero .hero__shell {
    position: relative;
    z-index: 60;
    display: flex;
    flex-direction: column;
    justify-content: center;
    height: 100%;
    padding: 0 32px;
    max-width: 1400px;
    margin-inline: auto;
    pointer-events: none;
  }

  .hero .hero__content {
    max-width: 640px;
    pointer-events: auto;
  }

  .hero .hero__tag {
    display: inline-block;
    padding: 6px 14px;
    margin-bottom: 32px;
    border-radius: 2px;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.70rem;
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    border: 1px solid rgba(255, 255, 255, 0.15);
  }

  .hero .hero__title {
    margin: 0 0 24px;
    font-family: "Inter Variable", "Inter", "DM Sans", system-ui, sans-serif;
    font-size: clamp(2.8rem, 6.4vw, 4.6rem);
    font-weight: 800;
    line-height: 1.06;
    letter-spacing: -0.03em;
  }

  .hero .hero__lead {
    margin: 0 0 48px;
    max-width: 32rem;
    font-size: clamp(1rem, 1.3vw, 1.2rem);
    font-weight: 300;
    line-height: 1.7;
  }

  .hero .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }

  .hero .hero__chip {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 14px 28px;
    border-radius: 2px;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    cursor: pointer;
    overflow: hidden;
    appearance: none;
    background: transparent;
    color: var(--ui-text-main);
    border: 1px solid rgba(255, 255, 255, 0.15);
    transition: color 0.4s cubic-bezier(0.19, 1, 0.22, 1), border-color 0.4s ease;
    z-index: 1;
  }

  .hero .hero__chip::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: var(--ui-text-main);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s cubic-bezier(0.19, 1, 0.22, 1);
    z-index: -1;
  }

  .hero .hero__chip:hover,
  .hero .hero__chip:focus-visible {
    color: var(--bg);
    border-color: transparent;
  }

  .hero .hero__chip:hover::before,
  .hero .hero__chip:focus-visible::before {
    transform: scaleX(1);
  }

  .hero .hero__chip--pop {
    position: relative;
  }

  .hero .hero__chip-qq {
    font-weight: 800;
    font-size: 0.95rem;
    line-height: 1;
  }

  .hero .hero__popover {
    position: absolute;
    bottom: calc(100% + 10px);
    left: 50%;
    transform: translateX(-50%);
    padding: 8px 14px;
    border-radius: 10px;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.72rem;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
  }

  .hero .hero__chip--pop:hover .hero__popover {
    opacity: 1;
  }

  @media (max-width: 640px) {
    .hero {
      height: auto;
      min-height: 720px;
    }

    .hero .hero__shell {
      padding: 0 20px;
    }
    .hero .hero__content {
      margin-top: 32px;
    }
    .hero .hero__title {
      font-size: clamp(2.2rem, 10vw, 3.2rem);
    }
    .hero .hero__lead {
      margin-bottom: 32px;
    }
  }
</style>
