---
import { site } from "../data/site";
---

<section class="hero" data-hero-root>
  <!-- WebGL Canvas 容器 -->
  <div class="webgl-hero-container" aria-hidden="true">
    <canvas id="webgl-canvas"></canvas>
  </div>

  <!-- 静态降级背景 (当 WebGL 失败时可见) -->
  <div class="hero-fallback-bg" aria-hidden="true"></div>

  <div class="ambient-glow" aria-hidden="true"></div>

  <div class="hero__shell">
    <div class="hero__content">
      <div class="hero__tag ui-glass ui-text-main">DIGITAL ATELIER // 01</div>

      <h1 class="hero__title ui-text-main">
        Between Code<br />
        and <span class="ui-gradient-text">Passing Light</span>
      </h1>

      <p class="hero__lead ui-text-muted">
        生活中，保存一些可被再次打开的瞬间。
      </p>

      <div class="hero__actions">
        <a
          href={site.github}
          target="_blank"
          rel="noreferrer"
          class="hero__chip ui-glass ui-text-main"
        >
          <span>GITHUB</span>
        </a>

        <div class="hero__chip hero__chip--pop ui-glass ui-text-main">
          <span>WECHAT</span>
          <div class="hero__popover ui-glass">暂不展示</div>
        </div>

        <button
          type="button"
          class="hero__chip ui-glass ui-text-main"
          data-email-copy={site.email}
        >
          <span>CONTACT</span>
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  import { Renderer, Camera, Transform, Plane, Program, Mesh, Texture } from 'ogl';

  const hero = document.querySelector<HTMLElement>("[data-hero-root]");
  const canvas = document.querySelector<HTMLCanvasElement>("#webgl-canvas");

  if (hero && canvas) {
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    // 交互状态变量
    let targetX = window.innerWidth / 2;
    let targetY = window.innerHeight / 2;
    let currentX = targetX;
    let currentY = targetY;
    let targetOpacity = 0;
    let currentOpacity = 0;

    let waveProgress = -0.3;
    let waveOpacity = 0;
    let isWaving = false;
    let sweepTimer = 0;
    let firstSweepScheduled = false;

    let animationId = 0;
    let isRunning = false;
    let inViewport = false;
    let time = 0;

    // 颜色渐变断点配置
    interface GradientColor {
      offset: number;
      color: string;
    }

    const ribbonsColorsDark: GradientColor[][] = [
      [
        { offset: 0, color: "#000000" },
        { offset: 0.15, color: "#090314" },
        { offset: 0.35, color: "#230d52" },
        { offset: 0.47, color: "#6432c9" },
        { offset: 0.495, color: "#a78aed" },
        { offset: 0.505, color: "#ffffff" },
        { offset: 0.515, color: "#a78aed" },
        { offset: 0.60, color: "#411a91" },
        { offset: 0.80, color: "#0f0529" },
        { offset: 1.0, color: "#000000" }
      ],
      [
        { offset: 0, color: "#000000" },
        { offset: 0.10, color: "#02171c" },
        { offset: 0.30, color: "#0a4c5e" },
        { offset: 0.46, color: "#209da8" },
        { offset: 0.495, color: "#8bf2ed" },
        { offset: 0.505, color: "#ffffff" },
        { offset: 0.515, color: "#8bf2ed" },
        { offset: 0.60, color: "#18786e" },
        { offset: 0.80, color: "#052b21" },
        { offset: 1.0, color: "#000000" }
      ],
      [
        { offset: 0, color: "#000000" },
        { offset: 0.10, color: "#1f0300" },
        { offset: 0.25, color: "#610f00" },
        { offset: 0.42, color: "#b82c00" },
        { offset: 0.485, color: "#f28d13" },
        { offset: 0.50, color: "#ffebb3" },
        { offset: 0.505, color: "#ffffff" },
        { offset: 0.51, color: "#ffebb3" },
        { offset: 0.58, color: "#d9660b" },
        { offset: 0.80, color: "#5e1400" },
        { offset: 1.0, color: "#000000" }
      ],
      [
        { offset: 0, color: "#000000" },
        { offset: 0.10, color: "#1f0012" },
        { offset: 0.30, color: "#5e0431" },
        { offset: 0.46, color: "#ab1862" },
        { offset: 0.495, color: "#f07ab9" },
        { offset: 0.505, color: "#ffffff" },
        { offset: 0.515, color: "#f07ab9" },
        { offset: 0.60, color: "#8f0e4d" },
        { offset: 0.80, color: "#240114" },
        { offset: 1.0, color: "#000000" }
      ]
    ];

    const ribbonsColorsLight: GradientColor[][] = [
      [
        { offset: 0, color: "var(--bg)" },
        { offset: 0.15, color: "#f3e8ff" },
        { offset: 0.35, color: "#d8b4fe" },
        { offset: 0.47, color: "#9333ea" },
        { offset: 0.505, color: "#ffffff" },
        { offset: 0.52, color: "#9333ea" },
        { offset: 0.65, color: "#d8b4fe" },
        { offset: 0.85, color: "#f3e8ff" },
        { offset: 1.0, color: "var(--bg)" }
      ],
      [
        { offset: 0, color: "var(--bg)" },
        { offset: 0.15, color: "#ccfbf1" },
        { offset: 0.35, color: "#5eead4" },
        { offset: 0.47, color: "#0d9488" },
        { offset: 0.505, color: "#ffffff" },
        { offset: 0.52, color: "#0d9488" },
        { offset: 0.65, color: "#5eead4" },
        { offset: 0.85, color: "#ccfbf1" },
        { offset: 1.0, color: "var(--bg)" }
      ],
      [
        { offset: 0, color: "var(--bg)" },
        { offset: 0.15, color: "#ffedd5" },
        { offset: 0.35, color: "#fdba74" },
        { offset: 0.47, color: "#ea580c" },
        { offset: 0.505, color: "#ffffff" },
        { offset: 0.52, color: "#ea580c" },
        { offset: 0.65, color: "#fdba74" },
        { offset: 0.85, color: "#ffedd5" },
        { offset: 1.0, color: "var(--bg)" }
      ],
      [
        { offset: 0, color: "var(--bg)" },
        { offset: 0.15, color: "#fce7f3" },
        { offset: 0.35, color: "#f9a8d4" },
        { offset: 0.47, color: "#db2777" },
        { offset: 0.505, color: "#ffffff" },
        { offset: 0.52, color: "#db2777" },
        { offset: 0.65, color: "#f9a8d4" },
        { offset: 0.85, color: "#fce7f3" },
        { offset: 1.0, color: "var(--bg)" }
      ]
    ];

    try {
      // 1. 初始化 OGL WebGL 渲染管线
      const renderer = new Renderer({
        canvas: canvas,
        alpha: true,
        premultipliedAlpha: true,
        antialias: true
      });
      const gl = renderer.gl;

      const camera = new Camera(gl, { fov: 45, near: 0.1, far: 100 });
      camera.position.set(0, 0, 8.5);

      const scene = new Transform();

      // 2. 动态创建 Canvas 2D 渐变精灵纹理
      const canvas2d = document.createElement("canvas");
      canvas2d.width = 512;
      canvas2d.height = 4;

      const texture = new Texture(gl, {
        generateMipmaps: false,
        minFilter: gl.LINEAR,
        magFilter: gl.LINEAR,
        wrapS: gl.CLAMP_TO_EDGE,
        wrapT: gl.CLAMP_TO_EDGE
      });

      const checkIsLightMode = () => {
        return (
          document.documentElement.classList.contains("light-mode") ||
          document.body.classList.contains("light-mode") ||
          document.documentElement.classList.contains("theme-preboot-light")
        );
      };

      const updateGradientTexture = () => {
        const ctx = canvas2d.getContext("2d");
        if (!ctx) return;
        const w = canvas2d.width;
        ctx.clearRect(0, 0, w, 4);

        const isLight = checkIsLightMode();
        const ribbons = isLight ? ribbonsColorsLight : ribbonsColorsDark;
        
        // 动态解析 Astro 主题的 --bg 变量
        const bgComputed = isLight 
          ? (getComputedStyle(document.documentElement).getPropertyValue('--bg').trim() || '#ffffff') 
          : '#000000';

        for (let i = 0; i < 4; i++) {
          const gradient = ctx.createLinearGradient(0, 0, w, 0);
          ribbons[i].forEach(stop => {
            let color = stop.color;
            if (color === "var(--bg)") {
              color = bgComputed;
            }
            gradient.addColorStop(stop.offset, color);
          });
          ctx.fillStyle = gradient;
          ctx.fillRect(0, i, w, 1);
        }

        texture.image = canvas2d;
        texture.needsUpdate = true;
      };

      // 触发初始渐变纹理绘制
      updateGradientTexture();

      // 3. 编写着色器与创建 Program
      const vertexShader = `
        attribute vec3 position;
        attribute vec2 uv;

        uniform mat4 modelViewMatrix;
        uniform mat4 projectionMatrix;
        uniform float uTime;
        uniform float uOffset;
        uniform float uWaveAmp;

        varying vec2 vUv;
        varying float vDepth;

        void main() {
            vUv = uv;
            vec3 pos = position;
            
            // 三角复合波形进行 3D 浮动形变
            float wave = sin(pos.y * 2.2 + uTime * 1.5 + uOffset) * 0.12 * uWaveAmp;
            pos.x += wave;
            pos.z += cos(pos.y * 1.8 + uTime * 1.2 + uOffset) * 0.08 * uWaveAmp;
            
            vec4 mvPosition = modelViewMatrix * vec4(pos, 1.0);
            gl_Position = projectionMatrix * mvPosition;
            vDepth = mvPosition.z;
        }
      `;

      const fragmentShader = `
        precision highp float;

        uniform sampler2D uGradientTex;
        uniform float uRibbonIndex;
        uniform vec2 uMouse;
        uniform vec2 uResolution;
        uniform float uBrightOpacity;
        uniform float uDimOpacity;
        uniform float uWaveProgress;
        uniform float uWaveOpacity;
        uniform float uTime;
        uniform float uNoiseIntensity;

        varying vec2 vUv;
        varying float vDepth;

        float random(vec2 st) {
            return fract(sin(dot(st.xy, vec2(12.9898, 78.233))) * 43758.5453123);
        }

        void main() {
            // 通过纵向 Y 坐标区分 4 条丝带色带
            float vCoord = (uRibbonIndex + 0.5) / 4.0;
            vec4 ribbonColor = texture2D(uGradientTex, vec2(vUv.x, vCoord));
            
            // 聚光灯跟随高光 (使用屏幕像素计算)
            float mouseDist = distance(gl_FragCoord.xy, uMouse);
            float mouseRadius = uResolution.x * 0.38; 
            float mouseMask = smoothstep(mouseRadius, 0.0, mouseDist) * uBrightOpacity;
            
            // 沿 Y 轴流动的线性扫光
            float distToWave = abs(vUv.y - uWaveProgress);
            float waveMask = smoothstep(0.18, 0.0, distToWave) * uWaveOpacity;
            
            // 合成最终色彩及微弱的透视深度雾化
            float mask = uDimOpacity + mouseMask + waveMask * 1.5;
            vec3 finalColor = ribbonColor.rgb * mask;
            
            float fog = smoothstep(-5.0, 2.0, vDepth);
            finalColor = mix(finalColor * 0.35, finalColor, fog);
            
            // 像素伪随机噪点叠加
            float noise = (random(gl_FragCoord.xy + uTime * 0.08) - 0.5) * uNoiseIntensity;
            finalColor += vec3(noise);
            
            gl_FragColor = vec4(finalColor, ribbonColor.a);
        }
      `;

      // 4. 建立细分树
      const geometry = new Plane(gl, {
        width: 1,
        height: 1,
        widthSegments: 1,
        heightSegments: 60
      });

      // 5. 按照 CSS 3D 原始排布，生成 4 条 Mesh
      const meshes: Mesh[] = [];
      const ribbonParams = [
        { index: 0.0, offset: 0.0, pos: [-3.2, 0, -1.0], rot: [0, -15, 5], scale: [1.9, 8.0, 1.0] },
        { index: 1.0, offset: 3.0, pos: [-1.0, 0, 0.0], rot: [0, -25, -2], scale: [2.2, 8.0, 1.0] },
        { index: 2.0, offset: 6.0, pos: [1.4, 0, 1.0], rot: [0, -35, -10], scale: [2.5, 8.0, 1.0] },
        { index: 3.0, offset: 9.0, pos: [3.8, 0, 2.0], rot: [0, -45, -18], scale: [2.1, 8.0, 1.0] }
      ];

      const uniforms = {
        uGradientTex: { value: texture },
        uTime: { value: 0 },
        uWaveAmp: { value: reducedMotion ? 0.0 : 1.0 },
        uMouse: { value: [currentX, currentY] },
        uResolution: { value: [gl.canvas.width, gl.canvas.height] },
        uBrightOpacity: { value: 0 },
        uDimOpacity: { value: checkIsLightMode() ? 0.95 : 0.45 },
        uWaveProgress: { value: waveProgress },
        uWaveOpacity: { value: waveOpacity },
        uNoiseIntensity: { value: 0.038 }
      };

      ribbonParams.forEach(param => {
        const program = new Program(gl, {
          vertex: vertexShader,
          fragment: fragmentShader,
          uniforms: {
            uGradientTex: uniforms.uGradientTex,
            uTime: uniforms.uTime,
            uWaveAmp: uniforms.uWaveAmp,
            uMouse: uniforms.uMouse,
            uResolution: uniforms.uResolution,
            uBrightOpacity: uniforms.uBrightOpacity,
            uDimOpacity: uniforms.uDimOpacity,
            uWaveProgress: uniforms.uWaveProgress,
            uWaveOpacity: uniforms.uWaveOpacity,
            uNoiseIntensity: uniforms.uNoiseIntensity,
            uRibbonIndex: { value: param.index },
            uOffset: { value: param.offset }
          },
          transparent: true,
          depthTest: true,
          depthWrite: false
        });

        const mesh = new Mesh(gl, { geometry, program });
        mesh.position.set(param.pos[0], param.pos[1], param.pos[2]);
        mesh.rotation.set(
          (param.rot[0] * Math.PI) / 180,
          (param.rot[1] * Math.PI) / 180,
          (param.rot[2] * Math.PI) / 180
        );
        mesh.scale.set(param.scale[0], param.scale[1], param.scale[2]);
        mesh.setParent(scene);
        meshes.push(mesh);
      });

      // 6. 自适应 Resize 处理
      const resize = () => {
        const width = hero.clientWidth;
        const height = hero.clientHeight;

        renderer.setSize(width, height);
        camera.perspective({ aspect: gl.canvas.width / gl.canvas.height });

        const aspect = width / height;
        if (aspect < 1.0) {
          scene.position.set(0.6, 0, 0);
          scene.scale.set(0.9, 0.9, 0.9);
        } else {
          scene.position.set(0, 0, 0);
          scene.scale.set(1.0, 1.0, 1.0);
        }

        uniforms.uResolution.value = [gl.canvas.width, gl.canvas.height];
      };

      window.addEventListener("resize", resize);
      resize();

      // 7. 亮暗模式切换 MutationObserver 同步
      const observerTheme = new MutationObserver(() => {
        updateGradientTexture();
        uniforms.uDimOpacity.value = checkIsLightMode() ? 0.95 : 0.45;
      });
      observerTheme.observe(document.documentElement, { attributes: true, attributeFilter: ["class"] });
      observerTheme.observe(document.body, { attributes: true, attributeFilter: ["class"] });

      // 8. 交互事件监听与缓动
      const onPointerMove = (e: PointerEvent) => {
        const rect = canvas.getBoundingClientRect();
        targetX = e.clientX - rect.left;
        targetY = rect.height - (e.clientY - rect.top);
        targetOpacity = 1.0;
        startAnimation();
      };

      const onPointerLeave = () => {
        targetOpacity = 0.0;
        startAnimation();
      };

      hero.addEventListener("pointermove", onPointerMove);
      hero.addEventListener("pointerleave", onPointerLeave);

      // 9. 流动扫光驱动
      const triggerSweep = () => {
        if (isWaving || reducedMotion) return;
        isWaving = true;
        waveProgress = -0.3;
        waveOpacity = 0.0;
        startAnimation();
      };

      const scheduleFirstSweep = () => {
        if (firstSweepScheduled || reducedMotion) return;
        firstSweepScheduled = true;
        window.setTimeout(triggerSweep, 1500);
      };

      const startSweepTimer = () => {
        if (sweepTimer || reducedMotion) return;
        sweepTimer = window.setInterval(triggerSweep, 10000);
      };

      const stopSweepTimer = () => {
        if (sweepTimer) {
          window.clearInterval(sweepTimer);
          sweepTimer = 0;
        }
      };

      // 10. 核心渲染循环 (Render Loop)
      const animate = () => {
        if (!isRunning) return;

        time += 0.01;
        uniforms.uTime.value = time;

        currentX += (targetX - currentX) * 0.08;
        currentY += (targetY - currentY) * 0.08;
        currentOpacity += (targetOpacity - currentOpacity) * 0.06;

        const dpr = window.devicePixelRatio || 1;
        uniforms.uMouse.value = [currentX * dpr, currentY * dpr];
        uniforms.uBrightOpacity.value = currentOpacity;

        if (isWaving) {
          waveProgress += 0.007;
          if (waveProgress <= 0.5) {
            waveOpacity = Math.min(0.85, waveOpacity + 0.016);
          } else if (waveProgress > 0.5 && waveOpacity > 0) {
            waveOpacity -= 0.038;
          }
          uniforms.uWaveProgress.value = waveProgress;
          uniforms.uWaveOpacity.value = Math.max(0.0, waveOpacity);

          if (waveProgress > 1.3) {
            isWaving = false;
            waveOpacity = 0.0;
            uniforms.uWaveOpacity.value = 0.0;
          }
        }

        renderer.render({ scene, camera });

        const isIdle =
          !isWaving &&
          Math.abs(targetX - currentX) < 0.2 &&
          Math.abs(targetY - currentY) < 0.2 &&
          Math.abs(targetOpacity - currentOpacity) < 0.001;

        if (isIdle) {
          stopAnimation();
          return;
        }

        animationId = requestAnimationFrame(animate);
      };

      const startAnimation = () => {
        if (isRunning || !inViewport || document.visibilityState === "hidden") return;
        isRunning = true;
        animationId = requestAnimationFrame(animate);
      };

      const stopAnimation = () => {
        isRunning = false;
        if (animationId) {
          cancelAnimationFrame(animationId);
          animationId = 0;
        }
      };

      // 11. IntersectionObserver 视口监控节能机制
      if ("IntersectionObserver" in window) {
        const observer = new IntersectionObserver(
          (entries) => {
            const visible = entries.some((entry) => entry.isIntersecting);
            inViewport = visible;
            if (visible) {
              startSweepTimer();
              scheduleFirstSweep();
              startAnimation();
            } else {
              stopSweepTimer();
              stopAnimation();
            }
          },
          { rootMargin: "0px", threshold: 0 }
        );
        observer.observe(hero);
      } else {
        inViewport = true;
        startSweepTimer();
        scheduleFirstSweep();
        startAnimation();
      }

      document.addEventListener("visibilitychange", () => {
        if (document.visibilityState === "hidden") {
          stopAnimation();
          stopSweepTimer();
        } else if (inViewport) {
          startSweepTimer();
          startAnimation();
        }
      });

    } catch (err) {
      console.warn("WebGL initialization failed, falling back to CSS background:", err);
      hero.classList.add("webgl-fallback");
    }
  }
</script>

<style is:global>
  .hero {
    position: relative;
    width: 100%;
    height: clamp(760px, 108dvh, 980px);
    min-height: 760px;
    overflow: hidden;
    isolation: isolate;
    color: var(--ui-text-main);
  }

  .hero[data-hero-wave-active] .ui-glass:hover,
  .hero[data-hero-wave-active] .ui-glass:focus-visible {
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  .hero .ambient-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background: var(--ambient-glow);
  }

  .hero::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 45;
    height: clamp(96px, 15vh, 180px);
    pointer-events: none;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      color-mix(in srgb, var(--bg) 24%, transparent) 62%,
      var(--bg) 100%
    );
  }

  .hero .webgl-hero-container {
    position: absolute;
    top: -12vh;
    right: -13vw;
    width: 82vw;
    height: 190vh;
    z-index: 1;
    pointer-events: none;
    contain: layout paint style;
    mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      #000 9%,
      #000 86%,
      rgba(0, 0, 0, 0.74) 94%,
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      #000 9%,
      #000 86%,
      rgba(0, 0, 0, 0.74) 94%,
      transparent 100%
    );
  }

  .hero #webgl-canvas {
    display: block;
    width: 100%;
    height: 100%;
  }

  .hero .hero-fallback-bg {
    position: absolute;
    top: -12vh;
    right: -13vw;
    width: 82vw;
    height: 190vh;
    z-index: 0;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s ease;
    background: linear-gradient(135deg, #090314 0%, #052b21 50%, #240114 100%);
    mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      #000 9%,
      #000 86%,
      rgba(0, 0, 0, 0.74) 94%,
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      #000 9%,
      #000 86%,
      rgba(0, 0, 0, 0.74) 94%,
      transparent 100%
    );
  }

  /* 亮色模式下的降级背景 */
  html.theme-preboot-light .hero .hero-fallback-bg,
  body.light-mode .hero .hero-fallback-bg {
    background: linear-gradient(135deg, #f3e8ff 0%, #ccfbf1 50%, #fce7f3 100%);
  }

  /* 当 WebGL 降级激活时，隐藏 Canvas，显示降级背景 */
  .hero.webgl-fallback .webgl-hero-container {
    display: none;
  }

  .hero.webgl-fallback .hero-fallback-bg {
    opacity: 0.65;
  }

  .hero .hero__shell {
    position: relative;
    z-index: 60;
    display: flex;
    flex-direction: column;
    justify-content: center;
    height: 100%;
    padding: 0 32px;
    max-width: 1400px;
    margin-inline: auto;
    pointer-events: none;
  }

  .hero .hero__content {
    max-width: 640px;
    pointer-events: auto;
  }

  .hero .hero__tag {
    display: inline-block;
    padding: 6px 14px;
    margin-bottom: 32px;
    border-radius: 2px;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.70rem;
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    border: 1px solid rgba(255, 255, 255, 0.15);
  }

  .hero .hero__title {
    margin: 0 0 24px;
    font-family: "Inter Variable", "Inter", "DM Sans", system-ui, sans-serif;
    font-size: clamp(2.8rem, 6.4vw, 4.6rem);
    font-weight: 800;
    line-height: 1.06;
    letter-spacing: -0.03em;
  }

  .hero .hero__lead {
