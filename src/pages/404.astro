---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";
---

<BaseLayout title={`404 · ${site.name}`} description="页面不存在。">
  <section class="section">
    <div class="copy-shell not-found surface-card">
      <p class="eyebrow">404 / missing</p>
      <h1>页面不在这里。</h1>
      <p>
        这个入口要么还没被建出来，要么已经被挪走了。回首页重新挑一条路径会更快。
      </p>
      <a class="button-primary" href="/">回到首页</a>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    padding: 36px;
  }

  .not-found h1 {
    margin: 0;
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1.05;
    letter-spacing: -0.05em;
  }

  .not-found p:not(.eyebrow) {
    color: var(--text-secondary);
  }
</style>
