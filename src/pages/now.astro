---
import { getCollection, render } from "astro:content";
import SectionHeading from "../components/SectionHeading.astro";
import { site } from "../data/site";
import { formatDate, sortByDateDesc } from "../lib/content";
import BaseLayout from "../layouts/BaseLayout.astro";

const entries = sortByDateDesc(await getCollection("now"));
const timeline = await Promise.all(
  entries.map(async (entry) => ({
    entry,
    rendered: await render(entry),
  })),
);

const visualTones = ["#d8d8d8", "#111111", "#c7c7c7", "#2a2a2a"];
---

<BaseLayout title={`Now · ${site.name}`} description="hui 的动态时间线。">
  <section class="section">
    <!-- Using a wider container for editorial layout to breathe. Added data-now-experience to hook up curtain script -->
    <div class="container container--editorial" data-now-experience>
      
      <div class="editorial-layout">
        
        <!-- Sticky Guide (Left side on desktop) -->
        <aside class="sticky-guide reveal-on-scroll">
          <SectionHeading index="03" label="状态" title="最近" />
          <p class="guide-lead">
            这是一些碎片化的记录。<br>
            关于我最近在做什么、思考什么。
          </p>
          <div class="guide-line" aria-hidden="true"></div>
        </aside>

        <!-- Timeline Feed (Right side on desktop) -->
        <div class="editorial-feed">
          {
            timeline.map(({ entry, rendered }, idx) => {
              // Stagger first few elements
              const delayAttr = idx < 4 ? `transition-delay: ${idx * 0.1}s` : "";

              return (
                <button 
                  type="button" 
                  class="editorial-card reveal-on-scroll" 
                  style={delayAttr} 
                  data-now-open={String(idx)}
                >
                  <div class="editorial-card__meta">
                    <span class="editorial-card__date">{formatDate(entry.data.date)}</span>
                    <span class="editorial-card__line"></span>
                    <span class="editorial-card__idx">LOG // {String(idx + 1).padStart(2, "0")}</span>
                  </div>
                  
                  <div class="editorial-card__content">
                    {entry.data.title && <h3 class="editorial-card__title">{entry.data.title}</h3>}
                    <p class="editorial-card__summary">{entry.data.summary}</p>
                  </div>
                </button>
              );
            })
          }
        </div>
      </div>

      <!-- Curtain & Detail Layer Ported from CHRONICLES -->
      <div class="now-editorial__curtain" aria-hidden="true"></div>

      <div class="now-editorial__detail-layer" aria-hidden="true">
        {
          timeline.map(({ entry, rendered }, index) => {
            const { Content } = rendered;

            return (
              <article
                class="now-editorial__detail"
                data-now-panel={String(index)}
                hidden
              >
                <div class="now-editorial__detail-topbar">
                  <span class="now-editorial__detail-index">
                    ARCHIVE LOG / {String(index + 1).padStart(2, "0")}
                  </span>

                  <button type="button" class="now-editorial__detail-close" data-now-close>
                    <span>RETURN / ESC</span>
                    <span class="now-editorial__close-icon" aria-hidden="true">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18" />
                        <line x1="6" y1="6" x2="18" y2="18" />
                      </svg>
                    </span>
                  </button>
                </div>

                <div class="now-editorial__detail-body">
                  <h3 class="now-editorial__detail-title">{entry.data.summary}</h3>

                  <div class="now-editorial__detail-meta">
                    <div>
                      <span>Date</span>
                      <strong>{formatDate(entry.data.date)}</strong>
                    </div>
                    <div>
                      <span>Type</span>
                      <strong>DATA LOG</strong>
                    </div>
                    <div>
                      <span>Mode</span>
                      <strong>TRANSMISSION</strong>
                    </div>
                    <div>
                      <span>Status</span>
                      <strong>Open</strong>
                    </div>
                  </div>

                  <div
                    class="now-editorial__detail-visual"
                    style={`--tone: ${visualTones[index % visualTones.length]};`}
                  >
                    <span>SIGNAL ACQUIRED // DETAILED VIEW</span>
                  </div>

                  <div class="now-editorial__detail-columns">
                    <div class="now-editorial__detail-lead">
                      <h4>DECRYPTING THE LATEST TRANSMISSION.</h4>
                    </div>

                    <div class="now-editorial__detail-copy">
                      <!-- Render the full article body inside the modal -->
                      {entry.data.title && <p class="now-editorial__detail-summary">{entry.data.title}</p>}
                      <div class="prose-shell">
                        <Content />
                      </div>
                    </div>
                  </div>
                </div>
              </article>
            );
          })
        }
      </div>

    </div>
  </section>
</BaseLayout>

<script>
  // ============================
  // Scroll Reveal Observer Object
  // ============================
  const observerOptions = {
    root: null,
    rootMargin: '0px 0px -10% 0px',
    threshold: 0.02
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);

  requestAnimationFrame(() => {
    document.querySelectorAll('.reveal-on-scroll').forEach(el => {
      observer.observe(el);
    });
  });

  // ============================
  // Curtain Modal Logic Hookup
  // ============================
  document.querySelectorAll<HTMLElement>("[data-now-experience]").forEach((root) => {
    const openButtons = Array.from(root.querySelectorAll<HTMLElement>("[data-now-open]"));
    const panels = Array.from(root.querySelectorAll<HTMLElement>("[data-now-panel]"));
    const closeButtons = Array.from(root.querySelectorAll<HTMLElement>("[data-now-close]"));
    const detailLayer = root.querySelector<HTMLElement>(".now-editorial__detail-layer");
    let openTimer = 0;
    let closeTimer = 0;

    const setActivePanel = (index: string | null) => {
      panels.forEach((panel) => {
        panel.hidden = panel.dataset.nowPanel !== index;
      });
    };

    const cleanupTimers = () => {
      if (openTimer) {
        window.clearTimeout(openTimer);
        openTimer = 0;
      }
      if (closeTimer) {
        window.clearTimeout(closeTimer);
        closeTimer = 0;
      }
    };

    const open = (index: string) => {
      cleanupTimers();
      setActivePanel(index);
      root.dataset.state = "entering";
      document.body.style.overflow = "hidden";

      openTimer = window.setTimeout(() => {
        root.dataset.state = "open";
        detailLayer?.setAttribute("aria-hidden", "false");
      }, 520);
    };

    const close = () => {
      if (root.dataset.state === "idle" || !root.dataset.state) {
        return;
      }

      cleanupTimers();
      root.dataset.state = "exiting";
      detailLayer?.setAttribute("aria-hidden", "true");

      closeTimer = window.setTimeout(() => {
        root.dataset.state = "idle";
        document.body.style.overflow = "";
        setActivePanel(null);
      }, 720);
    };

    openButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const index = button.dataset.nowOpen;
        if (index) {
          open(index);
        }
      });
    });

    closeButtons.forEach((button) => {
      button.addEventListener("click", close);
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        close();
      }
    });

    window.addEventListener(
      "beforeunload",
      () => {
        cleanupTimers();
        document.body.style.overflow = "";
      },
      { once: true },
    );
  });
</script>

<style>
  /* 
   * Container override for wider cinematic layout
   */
  .container--editorial {
    width: min(1080px, calc(100vw - 48px));
    margin-inline: auto;
  }

  /* 
   * Editorial Layout 
   */
  .editorial-layout {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 80px;
    margin-top: 40px;
    align-items: start;
  }

  .sticky-guide {
    position: sticky;
    top: 140px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    z-index: 10;
  }

  .guide-lead {
    color: var(--text-tertiary);
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
    max-width: 90%;
  }

  .guide-line {
    width: 1px;
    height: 140px;
    background: linear-gradient(to bottom, color-mix(in srgb, var(--text-tertiary) 40%, transparent), transparent);
    margin-top: 20px;
    margin-left: 2px;
  }

  /*
   * Editorial Feed (Right)
   */
  .editorial-feed {
    display: grid;
    gap: 40px;
    padding-bottom: 80px;
  }

  /*
   * Editorial Card Button
   */
  .editorial-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding: 32px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    background: transparent;
    color: inherit;
    text-align: left;
    cursor: pointer;
    transition: 
      border-color 0.4s var(--ease-cinema),
      transform 0.4s var(--ease-cinema);
  }

  :global(body.light-mode) .editorial-card {
    border-bottom-color: rgba(0, 0, 0, 0.05);
  }

  .editorial-card:hover,
  .editorial-card:focus-visible {
    border-bottom-color: rgba(255, 255, 255, 0.2);
  }

  :global(body.light-mode) .editorial-card:hover,
  :global(body.light-mode) .editorial-card:focus-visible {
    border-bottom-color: rgba(0, 0, 0, 0.2);
  }

  .editorial-card__meta {
    display: flex;
    align-items: center;
    gap: 16px;
    width: 100%;
    transition: transform 0.4s var(--ease-cinema);
  }

  .editorial-card:hover .editorial-card__meta,
  .editorial-card:focus-visible .editorial-card__meta {
    transform: translateX(10px);
  }

  .editorial-card__date {
    color: var(--text-secondary);
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    font-weight: 500;
  }

  .editorial-card__line {
    flex: 1;
    height: 1px;
    background: var(--border);
    opacity: 0.4;
  }

  .editorial-card__idx {
    color: var(--text-tertiary);
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.75rem;
    letter-spacing: 0.15em;
  }

  .editorial-card__content {
    padding-left: 2px;
    transition: transform 0.4s var(--ease-cinema);
  }

  .editorial-card:hover .editorial-card__content,
  .editorial-card:focus-visible .editorial-card__content {
    transform: translateX(10px);
  }

  .editorial-card__title {
    margin: 0 0 16px;
    font-size: clamp(1.8rem, 3vw, 2.3rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--text-primary);
  }

  .editorial-card__summary {
    margin: 0;
    color: var(--text-secondary);
    font-size: 1.15rem;
    line-height: 1.6;
    font-weight: 400;
  }

  /*
   * Interaction & Micro-animations
   */
  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(30px) scale(0.98);
    will-change: opacity, transform;
  }

  .reveal-on-scroll.is-visible {
    opacity: 1;
    transform: translateY(0) scale(1);
    /* Restore normal pointer events / hover states after reveal */
  }

  /* ============================
   * Curtain Modal Styles Ported
   * ============================ */
   .now-editorial__curtain {
    position: fixed;
    inset: 0;
    z-index: 220;
    pointer-events: none;
    transform: translateY(100%);
    background: var(--text-primary);
    transition: transform 0.6s cubic-bezier(0.7, 0, 0.2, 1);
  }

  .now-editorial__detail-layer {
    position: fixed;
    inset: 0;
    z-index: 230;
    overflow-y: auto;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    background: var(--bg);
    color: var(--text-primary);
    transition: opacity 0.4s ease;
  }

  [data-state="entering"] .now-editorial__curtain,
  [data-state="open"] .now-editorial__curtain {
    transform: translateY(0);
  }

  [data-state="exiting"] .now-editorial__curtain {
    transform: translateY(-100%);
  }

  [data-state="open"] .now-editorial__detail-layer {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .now-editorial__detail {
    min-height: 100%;
    padding: 96px 24px 80px;
  }

  .now-editorial__detail-topbar,
  .now-editorial__detail-body {
    width: min(1200px, calc(100vw - 48px));
    margin-inline: auto;
  }

  .now-editorial__detail-topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 48px;
  }

  .now-editorial__detail-index {
    color: var(--text-tertiary);
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .now-editorial__detail-close {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 16px;
    min-height: 40px;
    padding: 0 20px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 2px;
    background: transparent;
    color: inherit;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.70rem;
    font-weight: 500;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    cursor: pointer;
    overflow: hidden;
    transition: color 0.4s cubic-bezier(0.19, 1, 0.22, 1);
    z-index: 1;
  }

  .now-editorial__detail-close::before {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: var(--text-primary);
    transform: scaleY(0);
    transform-origin: bottom;
    transition: transform 0.4s cubic-bezier(0.19, 1, 0.22, 1);
    z-index: -1;
  }

  .now-editorial__close-icon {
    display: flex;
    transition: transform 0.4s cubic-bezier(0.19, 1, 0.22, 1);
  }

  .now-editorial__detail-close:hover,
  .now-editorial__detail-close:focus-visible {
    color: var(--bg);
    outline: none;
  }

  .now-editorial__detail-close:hover::before,
  .now-editorial__detail-close:focus-visible::before {
    transform: scaleY(1);
  }

  .now-editorial__detail-close:hover .now-editorial__close-icon,
  .now-editorial__detail-close:focus-visible .now-editorial__close-icon {
    transform: rotate(90deg);
  }

  :global(body.light-mode) .now-editorial__detail-close {
    border-color: rgba(0, 0, 0, 0.15);
  }

  .now-editorial__detail-title {
    margin: 0;
    max-width: 12ch;
    font-size: clamp(3.4rem, 9vw, 8.4rem);
    font-weight: 800;
    line-height: 0.85;
    letter-spacing: -0.08em;
  }

  .now-editorial__detail-meta {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0;
    margin-top: 32px;
    padding: 28px 0;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .now-editorial__detail-meta > div {
    display: grid;
    gap: 10px;
  }

  .now-editorial__detail-meta > div + div {
    padding-left: 24px;
    border-left: 1px solid rgba(255, 255, 255, 0.08);
  }

  .now-editorial__detail-meta span {
    color: var(--text-tertiary);
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.68rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .now-editorial__detail-meta strong {
    font-size: clamp(1rem, 1.8vw, 1.45rem);
    font-weight: 500;
    line-height: 1.2;
  }

  .now-editorial__detail-visual {
    position: relative;
    margin-top: 28px;
    aspect-ratio: 21 / 9;
    overflow: hidden;
    background: var(--tone);
  }

  .now-editorial__detail-visual::before {
    content: "";
    position: absolute;
    inset: 0;
    opacity: 0.3;
    mix-blend-mode: overlay;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
  }

  .now-editorial__detail-visual span {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    mix-blend-mode: difference;
  }

  .now-editorial__detail-columns {
    display: grid;
    grid-template-columns: minmax(240px, 0.8fr) minmax(0, 1.2fr);
    gap: 48px;
    margin-top: 40px;
  }

  .now-editorial__detail-lead h4 {
    margin: 0;
    font-size: clamp(2rem, 3vw, 3rem);
    line-height: 0.98;
    letter-spacing: -0.05em;
  }

  .now-editorial__detail-summary {
    margin: 0 0 20px;
    color: var(--text-primary);
    font-size: 1.16rem;
    line-height: 1.5;
  }

  /* 
   * Responsive Fallbacks 
   */
  @media (max-width: 980px) {
    .now-editorial__detail-meta {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 20px;
    }
    .now-editorial__detail-meta > div + div {
      padding-left: 0;
      border-left: 0;
    }
    .now-editorial__detail-columns {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }

  @media (max-width: 900px) {
    .editorial-layout {
      grid-template-columns: 1fr;
      gap: 50px;
    }

    .sticky-guide {
      position: relative;
      top: 0;
      gap: 16px;
    }

    .guide-line {
      display: none;
    }

    .editorial-card__title {
      font-size: 1.6rem;
    }
  }

  @media (max-width: 720px) {
    .now-editorial__detail {
      padding-top: 84px;
    }
    .now-editorial__detail-topbar {
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
    }
    .now-editorial__detail-meta {
      grid-template-columns: 1fr;
    }
  }
</style>
